# =====================================================================
# KusumaVision NMS — konfigurasi Docker (host-side).
# Salin file ini menjadi ".env" lalu ubah minimal DB_PASSWORD & admin:
#     cp .env.docker.example .env
# File ini dibaca oleh docker-compose (bukan .env Laravel di dalam container).
# =====================================================================

# Port di PC untuk membuka aplikasi → http://localhost:<APP_PORT>
APP_PORT=8080

APP_NAME="KusumaVision NMS"
APP_URL=http://localhost:8080

# Biarkan KOSONG → digenerate otomatis sekali & disimpan permanen di volume.
# (Isi hanya bila ingin memakai key dari instalasi lain, format base64:...)
APP_KEY=

# ---- Database (PostgreSQL, jalan di container "db") ----
DB_DATABASE=kusumavision_nms
DB_USERNAME=kusumavision
DB_PASSWORD=ubah_password_ini

# ---- ACS / TR069 (default bawaan aplikasi) ----
ACS_URL=http://acs.bmkv.net:7547
ACS_USERNAME=cms
ACS_PASSWORD=kusuma123!

# ---- Akun admin awal (opsional) ----
# Diisi hanya dipakai saat instalasi PERTAMA (tabel users masih kosong).
# Kosongkan untuk membuat admin manual: docker compose exec app php artisan user:create
ADMIN_NAME=Administrator
ADMIN_EMAIL=
ADMIN_PASSWORD=
